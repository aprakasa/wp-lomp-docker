# ── Project ──────────────────────────────────────
COMPOSE_PROJECT_NAME=wp

# ── Domain ──────────────────────────────────────
DOMAIN=localhost
EMAIL=admin@example.com

# ── MariaDB ─────────────────────────────────────
# WARNING: Change these passwords before deployment!
# NOTE: Wrap values in double quotes if they contain special characters (# $ ! @ etc.)
MYSQL_ROOT_PASSWORD="root_secure_password_change_me"
MYSQL_DATABASE=wordpress
MYSQL_USER=wp_user
MYSQL_PASSWORD="secure_password_change_me"

# ── WordPress ───────────────────────────────────
WORDPRESS_TABLE_PREFIX=wp_
WP_ADMIN_USER=admin
# WARNING: Change this password before deployment!
WP_ADMIN_PASSWORD="changeme"
WP_ADMIN_EMAIL=admin@example.com
WP_SITE_TITLE=My WordPress Site

# ── Redis ───────────────────────────────────────
REDIS_MAXMEMORY=64mb

# ── OpenLiteSpeed ───────────────────────────────
OLS_WORKERS=4

# ── SSL ──────────────────────────────────────────
# Set SSL=1 to auto-provision Let's Encrypt via acme.sh sidecar
# Requires a real DOMAIN (not localhost) and port 80 reachable
SSL=0
# Use Let's Encrypt staging server to avoid rate limits while testing
SSL_STAGING=0

# ── General ──────────────────────────────────────
TZ=UTC
